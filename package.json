{
  "name": "@nexusharness/cli",
  "version": "2.1.0-beta.0",
  "type": "module",
  "description": "Local-first AI coding harness for Ollama, LM Studio, llama.cpp, MCP tools, and auditable agentic workflows.",
  "bin": {
    "nexus": "dist-server/cli/index.js"
  },
  "files": [
    "dist-server/",
    "dist/",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "npm-shrinkwrap.json",
    ".env.example"
  ],
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"tsx server/index.ts\" \"wait-on http://127.0.0.1:8787/api/state && vite --host 127.0.0.1\"",
    "dev:api": "tsx server/index.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "start": "node dist-server/server/index.js",
    "cli": "node dist-server/cli/index.js",
    "test": "vitest run",
    "test:a11y": "vitest run tests/accessibility.browser.test.ts",
    "test:performance": "vitest run tests/performance.browser.test.ts",
    "test:smoke": "node scripts/smoke.mjs",
    "test:workflows": "vitest run tests/workflow.browser.test.ts",
    "verify:package": "node scripts/packageDryRun.mjs",
    "test:package": "npm run build && npm run verify:package",
    "test:cli": "vitest run tests/deploymentPaths.test.ts tests/lifecycle.test.ts tests/cli.integration.test.ts",
    "prepack": "npm run build && npm run verify:package",
    "release:artifacts": "node scripts/release/prepareRelease.mjs",
    "release:smoke": "node scripts/release/smokeTarball.mjs release-artifacts",
    "release:verify-artifacts": "node scripts/release/verifyArtifacts.mjs release-artifacts",
    "test:memory": "vitest run tests/memoryRetrieval.test.ts tests/vectorMemory.integration.test.ts tests/memoryRuntime.e2e.test.ts",
    "memory:migrate": "tsx scripts/memory.ts migrate",
    "memory:backfill": "tsx scripts/memory.ts backfill",
    "memory:reembed": "tsx scripts/memory.ts reembed",
    "memory:diagnostics": "tsx scripts/memory.ts diagnostics",
    "memory:evaluate": "tsx scripts/memoryEvaluation.ts",
    "memory:benchmark": "tsx scripts/memoryBenchmark.ts",
    "test:windows-sandbox": "tsx scripts/windowsSandboxProbe.ts",
    "test:windows-sandbox-command": "tsx scripts/windowsSandboxCommandProbe.ts",
    "test:visual": "vitest run tests/visual.browser.test.ts",
    "test:visual:update": "vitest run tests/visual.browser.test.ts",
    "lint": "eslint .",
    "control:status": "node control/scripts/control.mjs status",
    "control:claim": "node control/scripts/control.mjs claim",
    "control:heartbeat": "node control/scripts/control.mjs heartbeat",
    "control:takeover": "node control/scripts/control.mjs takeover",
    "control:release": "node control/scripts/control.mjs release",
    "control:board": "node control/scripts/control.mjs board",
    "control:verify": "node control/scripts/control.mjs verify",
    "version:check": "node scripts/version.mjs check",
    "version:sync": "node scripts/version.mjs sync",
    "release:verify": "npm run control:verify && npm run version:check && npm run lint && npm test && npm run build && npm run test:a11y && npm run test:workflows && npm run test:visual && npm run test:performance && npm run test:smoke && npm run test:package"
  },
  "keywords": [
    "local-ai",
    "coding-agent",
    "mcp",
    "ollama",
    "lm-studio",
    "llama.cpp"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmitriy718/nexusharness.git"
  },
  "homepage": "https://github.com/dmitriy718/nexusharness#readme",
  "bugs": {
    "url": "https://github.com/dmitriy718/nexusharness/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "esbuild@0.28.1": true,
    "onnxruntime-node@1.24.3": true,
    "protobufjs@7.6.5": true,
    "sharp@0.34.5": true
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/diff": "^7.0.2",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "js-tiktoken": "^1.0.21",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
