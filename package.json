{
  "name": "nexusharness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first AI coding harness for Ollama, LM Studio, llama.cpp, MCP tools, and auditable agentic workflows.",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"tsx server/index.ts\" \"wait-on http://127.0.0.1:8787/api/state && vite --host 127.0.0.1\"",
    "dev:api": "tsx server/index.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "keywords": [
    "local-ai",
    "coding-agent",
    "mcp",
    "ollama",
    "lm-studio",
    "llama.cpp"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/diff": "^7.0.2",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
