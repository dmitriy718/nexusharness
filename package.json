{
  "name": "nexusharness",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Local-first AI coding harness for Ollama, LM Studio, llama.cpp, MCP tools, and auditable agentic workflows.",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"tsx server/index.ts\" \"wait-on http://127.0.0.1:8787/api/state && vite --host 127.0.0.1\"",
    "dev:api": "tsx server/index.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.server.json && vite build",
    "start": "node dist-server/server/index.js",
    "test": "vitest run",
    "test:a11y": "vitest run tests/accessibility.browser.test.ts",
    "test:performance": "vitest run tests/performance.browser.test.ts",
    "test:smoke": "node scripts/smoke.mjs",
    "test:workflows": "vitest run tests/workflow.browser.test.ts",
    "test:package": "node scripts/packageDryRun.mjs",
    "test:windows-sandbox": "tsx scripts/windowsSandboxProbe.ts",
    "test:windows-sandbox-command": "tsx scripts/windowsSandboxCommandProbe.ts",
    "test:visual": "vitest run tests/visual.browser.test.ts",
    "test:visual:update": "vitest run tests/visual.browser.test.ts",
    "lint": "eslint .",
    "control:status": "node control/scripts/control.mjs status",
    "control:claim": "node control/scripts/control.mjs claim",
    "control:heartbeat": "node control/scripts/control.mjs heartbeat",
    "control:takeover": "node control/scripts/control.mjs takeover",
    "control:release": "node control/scripts/control.mjs release",
    "control:board": "node control/scripts/control.mjs board",
    "control:verify": "node control/scripts/control.mjs verify",
    "version:check": "node scripts/version.mjs check",
    "version:sync": "node scripts/version.mjs sync",
    "release:verify": "npm run control:verify && npm run version:check && npm run lint && npm test && npm run build && npm run test:a11y && npm run test:workflows && npm run test:visual && npm run test:performance && npm run test:smoke && npm run test:package"
  },
  "keywords": [
    "local-ai",
    "coding-agent",
    "mcp",
    "ollama",
    "lm-studio",
    "llama.cpp"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/diff": "^7.0.2",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "diff": "^9.0.0",
    "express": "^4.21.2",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.17.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "jsdom": "^29.1.1",
    "pixelmatch": "^7.2.0",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
