# NexusHarness binds to loopback by design. Change only if you understand the local security impact.
NEXUSHARNESS_PORT=8787

# Optional. Overrides the per-user NexusHarness data root. By default NexusHarness
# uses LocalAppData on Windows, Application Support on macOS, and XDG paths on Linux.
# NEXUSHARNESS_DATA_DIR=D:\projects\nexus-data

# Optional. Sets the initial workspace for a new data store. Without an override,
# NexusHarness creates a safe empty workspace under its per-user data directory.
# NEXUSHARNESS_WORKSPACE_ROOT=D:\projects

# Optional. Used only by the OpenAI-compatible embedding provider. The value is
# read at request time and is never persisted in store.json or returned by the API.
# NEXUSHARNESS_EMBEDDING_API_KEY=
